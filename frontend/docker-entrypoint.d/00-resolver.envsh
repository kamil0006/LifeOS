#!/bin/sh
# Sourced by the nginx image entrypoint before config templates are rendered.
# nginx's `resolver` directive does not read /etc/resolv.conf, so we export the
# container's nameserver(s) for nginx.conf.template as ${DNS_RESOLVER}.
# IPv6 nameservers must be bracketed for nginx (Railway's private DNS is IPv6).
DNS_RESOLVER="$(awk '/^nameserver/ { ns = ($2 ~ /:/) ? "[" $2 "]" : $2; printf "%s ", ns }' /etc/resolv.conf)"
export DNS_RESOLVER="${DNS_RESOLVER:-127.0.0.11}"
