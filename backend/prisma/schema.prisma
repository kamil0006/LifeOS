generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenseCategories  ExpenseCategory[]
  expenses    Expense[]
  scheduledExpenses ScheduledExpense[]
  income      Income[]
  todos       Todo[]
  wishes      Wish[]
  events      Event[]
  habits      Habit[]
  habitCheckIns HabitCheckIn[]
  goals       Goal[]
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   // hex, np. "#ff00d4"
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model Expense {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  category  String
  date      DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model ScheduledExpense {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  amount     Float
  category   String
  dayOfMonth Int      // 1-31, dzień miesiąca
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Income {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source    String
  amount    Float
  date      DateTime
  recurring Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model Todo {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  /// Data terminu (bez strefy — dzień kalendarzowy)
  dueDate   DateTime? @db.Date
  /// Opcjonalna godzina „HH:mm”
  dueTime   String?
  /// low | medium | high
  priority  String    @default("medium")
  /// dom | praca | finanse | nauka | zdrowie | inne
  category  String    @default("inne")
  archivedAt DateTime?
  noteId    String?

  @@index([userId])
  @@index([userId, done])
}

model Wish {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  estimatedPrice Float
  priority       Int      @default(2)
  stage          String   @default("pomysl")  // pomysl | chce_kupic | odkladam | kupione
  savedAmount    Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())

  @@index([userId])
}

model Event {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime
  time      String?  // np. "14:00"
  category  String?  // Praca, Prywatne, Zdrowie, Rozrywka, Inne
  color     String?  // hex, np. "#00e5ff"
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model Habit {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  category     String?
  color        String?
  /// daily | weekdays | weekly | monthly
  scheduleType String   @default("daily")
  /// Dni tygodnia dla scheduleType=weekdays (0 = niedziela ... 6 = sobota).
  scheduleDays Int[]    @default([])
  weeklyTarget Int?
  monthlyTarget Int?
  /// Etykieta jednostki (np. km, min) — tylko UI; null = nawyk binarny (tak/nie).
  unit         String?
  /// Opcjonalny dzienny cel liczbowy (np. 10 km). Przy braku — wpis liczy się sumarycznie bez procentu „celu dnia”.
  targetPerDay Float?
  createdAt    DateTime @default(now())
  archivedAt   DateTime?
  checkIns     HabitCheckIn[]

  @@index([userId])
  @@index([userId, archivedAt])
}

model HabitCheckIn {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  /// done | missed | skipped
  status    String   @default("done")
  /// Wykonana ilość; null = zaznaczenie bez liczby (kompatybilność / nawyk binarny).
  value     Float?
  note      String?
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([userId])
  @@index([habitId, date])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  target    Float
  current   Float    @default(0)
  unit      String?
  createdAt DateTime @default(now())

  @@index([userId])
}
