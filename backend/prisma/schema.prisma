generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Pierwsze pobranie kategorii wydatków – jednorazowy zestaw domyślnych; brak ponownego seedu po usunięciu wszystkich.
  financesCategoriesSeededAt DateTime?
  /// Znacznik czasu ostatniego wykonanego eksportu backupu — do przypomnienia w UI.
  lastBackupAt DateTime?

  expenseCategories  ExpenseCategory[]
  expenses    Expense[]
  scheduledExpenses ScheduledExpense[]
  income      Income[]
  todos       Todo[]
  events      Event[]
  habits      Habit[]
  habitCheckIns HabitCheckIn[]
  goals       Goal[]
  netWorthAccounts NetWorthAccount[]
  netWorthAdjustments NetWorthAdjustment[]
  notes       Note[]
  learningSessions LearningSession[]
  courses     Course[]
  projects    Project[]
  books       Book[]
  certifications Certification[]
  learningSettings LearningSettings?
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   // hex, np. "#ff00d4"
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model Expense {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  amount         Float
  category       String
  date           DateTime
  /// card | cash — opcjonalne dla starych wpisów sprzed migracji
  paymentMethod  String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model ScheduledExpense {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  amount     Float
  category   String
  dayOfMonth Int      // 1-31, dzień miesiąca
  active     Boolean  @default(true)
  /// card | cash — opcjonalne dla starych wpisów sprzed migracji
  paymentMethod String?
  pausedUntil DateTime? @db.Date
  reminderDaysBefore Int?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model NetWorthAccount {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  /// asset | liability
  kind      String
  balance   Float    @default(0)
  iconKey   String?
  accentKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  adjustments NetWorthAdjustment[]

  @@index([userId])
  @@index([userId, kind])
}

model NetWorthAdjustment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String
  account   NetWorthAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount    Float
  description String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([accountId, createdAt])
}

model Income {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source         String
  amount         Float
  date           DateTime
  recurring      Boolean  @default(false)
  /// Klucz kategorii jak w Expense (np. nazwa z ExpenseCategory lub pusty string)
  category       String   @default("")
  /// card | cash — opcjonalne dla starych wpisów sprzed migracji
  paymentMethod  String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model Todo {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  /// Data terminu (bez strefy — dzień kalendarzowy)
  dueDate   DateTime? @db.Date
  /// Opcjonalna godzina „HH:mm”
  dueTime   String?
  /// low | medium | high
  priority  String    @default("medium")
  /// dom | praca | finanse | nauka | zdrowie | inne
  category  String    @default("inne")
  archivedAt DateTime?
  noteId    String?
  linkedEventId String?

  @@index([userId])
  @@index([userId, done])
}

model Event {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime
  time      String?  // np. "14:00"
  category  String?  // Praca, Prywatne, Zdrowie, Rozrywka, Inne
  color     String?  // hex, np. "#00e5ff"
  notes     String?
  linkedTodoId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model Habit {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  category     String?
  color        String?
  /// daily | weekdays | weekly | monthly
  scheduleType String   @default("daily")
  /// Dni tygodnia dla scheduleType=weekdays (0 = niedziela ... 6 = sobota).
  scheduleDays Int[]    @default([])
  weeklyTarget Int?
  monthlyTarget Int?
  /// Etykieta jednostki (np. km, min) — tylko UI; null = nawyk binarny (tak/nie).
  unit         String?
  /// Opcjonalny dzienny cel liczbowy (np. 10 km). Przy braku — wpis liczy się sumarycznie bez procentu „celu dnia”.
  targetPerDay Float?
  createdAt    DateTime @default(now())
  archivedAt   DateTime?
  checkIns     HabitCheckIn[]

  @@index([userId])
  @@index([userId, archivedAt])
}

model HabitCheckIn {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  /// done | missed | skipped
  status    String   @default("done")
  /// Wykonana ilość; null = zaznaczenie bez liczby (kompatybilność / nawyk binarny).
  value     Float?
  note      String?
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([userId])
  @@index([habitId, date])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  target    Float
  current   Float    @default(0)
  unit      String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// inbox | idea | reference
  type      String   @default("inbox")
  content   String
  tags      String[] @default([])
  title     String?
  pinned    Boolean  @default(false)
  archivedAt DateTime?
  /// nowy | do_sprawdzenia | w_realizacji | zrobiony | odrzucony (tylko dla type=idea)
  ideaStatus String  @default("nowy")
  /// link | ksiazka | artykul | wideo | cytat | inne (tylko dla type=reference)
  referenceKind String @default("link")
  referenceUrl String?
  referenceSource String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, type])
  @@index([userId, archivedAt])
}

model LearningSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Dzień kalendarzowy "YYYY-MM-DD"
  date      String
  minutes   Int
  topic     String
  /// kurs | ksiazka | projekt | praktyka | powtorka | inne
  type      String
  category  String?
  note      String?
  courseId  String?
  projectId String?
  bookId    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model Course {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  platform    String?
  platformUrl String?
  progress    Int      @default(0)
  /// w_trakcie | ukonczony | zaplanowany
  status      String   @default("w_trakcie")
  startedAt   String?
  completedAt String?
  nextLesson  String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  tech        String?
  /// pomysl | w_trakcie | mvp | ukonczony | porzucony
  status      String   @default("w_trakcie")
  url         String?
  githubUrl   String?
  nextStep    String?
  /// niski | sredni | wysoki
  priority    String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Book {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  author      String?
  category    String?
  /// chce_przeczytac | czytam | przeczytane
  status      String   @default("chce_przeczytac")
  finishedAt  String?
  startedAt   String?
  rating      Int?
  notes       String?
  keyTakeaway String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Certification {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  issuer          String
  date            String
  url             String?
  expiryDate      String?
  verificationUrl String?
  renewalReminderDays Int?
  createdAt       DateTime @default(now())

  @@index([userId])
}

model LearningSettings {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyGoalMinutes Int      @default(600)
  sessionCategories String[] @default([])
  bookCategories    String[] @default([])
  updatedAt         DateTime @updatedAt
}
