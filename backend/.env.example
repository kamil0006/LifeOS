DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lifeos"
JWT_SECRET="your-super-secret-key-change-in-production"
PORT=3002
FRONTEND_URL="http://localhost:5173"

# Asystent AI (opcjonalne). Bez klucza backend generuje raport regułowy (bez AI).
# Klucz trzymany WYŁĄCZNIE po stronie backendu — nigdy we frontendzie.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Prompt systemowy asystenta (poza repo). Pusty = generyczny fallback z kodu.
# \n oznacza nową linię. Tu wpisz własny, szczegółowy prompt w prywatnym .env.
AI_SYSTEM_PROMPT=""
