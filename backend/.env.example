DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lifeos"
JWT_SECRET="your-super-secret-key-change-in-production-min-32-chars"
PORT=3002
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Rejestracja: domyślnie włączona lokalnie, w produkcji ustaw true aby umożliwić
REGISTRATION_ENABLED=true

# Sesja: access cookie (1h) + refresh cookie (7d / 24h). JWT nie trafia do localStorage.
ALLOW_DEV_RESET=false

# Szyfrowanie pól wrażliwych (notatki + opisy finansów: nazwy transakcji, źródła przychodów, konta).
# Wymaga 32-bajtowego klucza base64. Kwoty pozostają w DB jako liczby (sortowanie/filtry).
# Wygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_ENABLED=false
ENCRYPTION_KEY=""

# Asystent AI — domyślnie WYŁĄCZONY. Wymaga obu flag + klucza OpenAI.
AI_REPORT_ENABLED=false
AI_USE_OPENAI=false
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Prompt systemowy asystenta (poza repo). Pusty = generyczny fallback z kodu.
AI_SYSTEM_PROMPT=""
